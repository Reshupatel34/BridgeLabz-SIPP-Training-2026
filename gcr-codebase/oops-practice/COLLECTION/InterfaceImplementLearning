package COLLECTION;

interface Animal {
    void sound();
}

interface Pet {
    void play();
}

class Dog implements Animal, Pet {

    @Override
    public void sound() {
        System.out.println("Dog barks");
    }

    @Override
    public void play() {
        System.out.println("Dog plays with ball");
    }
}

public class InterfaceImplementLearning {

    public static void main(String[] args) {

        Dog d = new Dog();

        d.sound();
        d.play();
    }
}